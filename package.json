		"drizzle-orm": "^0.38.0",
		"electrobun": "1.16.0",
		"extract-zip": "^2.0.1",
		"gray-matter": "^4.0.3",
		"imapflow": "^1.2.12",
		"lucide-react": "^0.460.0",
		"mermaid": "^11.14.0",
		"nodemailer": "^8.0.1",
